rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regra para a coleção premium_emails (usada para pre-aprovar premium)
    match /premium_emails/{emailId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email == 'lpresses17@gmail.com' || request.auth.token.email == 'Lpresses17@gmail.com');
    }

    match /users/{userId} {
      allow list: if request.auth != null && (request.auth.token.email == 'lpresses17@gmail.com' || request.auth.token.email == 'Lpresses17@gmail.com');
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'lpresses17@gmail.com' || request.auth.token.email == 'Lpresses17@gmail.com');
      
      match /{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'lpresses17@gmail.com' || request.auth.token.email == 'Lpresses17@gmail.com');
      }
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
