rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que qualquer usuário autenticado crie um documento para si mesmo
    // Permite que o usuário logado leia, escreva e edite APENAS o seu próprio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'lpresses17@gmail.com');
      
      // As subcoleções do usuário (projetos, auditorias, etc) herdam a mesma regra
      match /{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'lpresses17@gmail.com');
      }
    }
    
    // Nenhuma outra coleção externa é permitida por segurança
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
